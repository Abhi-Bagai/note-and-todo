{
  "name": "notes-todo-app",
  "version": "1.0.0",
  "description": "Electron + React + Tailwind + SQLite notes and todo desktop app",
  "author": "Abhi Bagai",
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder --dir --config electron.config.js",
    "build:installer": "vite build && electron-builder --config electron.config.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "vite": "^5.2.8",
    "wait-on": "^7.2.0"
  }
}
